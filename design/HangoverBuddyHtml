<title>Hangover Buddy — Redesign</title>
<style>
/* Hangover Buddy — dark nocturnal editorial
   Palettes are swappable via [data-palette] on <body>. */

:root {
  --font-display: 'Fraunces', 'Cormorant Garamond', 'Times New Roman', serif;
  --font-sans: 'Inter', -apple-system, system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', 'SF Mono', ui-monospace, monospace;

  /* dusk palette (default) */
  --bg:        #0B0D10;
  --bg-2:      #14181D;
  --bg-3:      #1C2128;
  --line:      #242B33;
  --line-2:    #2F3842;
  --ink:       #F2EEE6;
  --ink-2:     #B7B1A6;
  --ink-3:     #7B7468;
  --accent:    #E8C27A;   /* warm amber, whiskey */
  --accent-2:  #B45B4F;   /* rust */
  --green:     #7FB68A;
  --yellow:    #E8C27A;
  --red:       #D96A6A;
  --blue:      #7BA6C4;

  --radius-sm: 10px;
  --radius-md: 18px;
  --radius-lg: 26px;
}

body[data-palette="neon"] {
  --bg:        #07080B;
  --bg-2:      #0E1118;
  --bg-3:      #161B25;
  --line:      #1F2637;
  --line-2:    #2B3449;
  --ink:       #EEF1FA;
  --ink-2:     #A5ADC2;
  --ink-3:     #6A7185;
  --accent:    #7CE7C7;   /* mint */
  --accent-2:  #C28BFF;   /* violet */
  --green:     #7CE7C7;
  --yellow:    #F3D35A;
  --red:       #FF6B7A;
  --blue:      #8DB8FF;
}

body[data-palette="paper"] {
  --bg:        #F4EFE4;
  --bg-2:      #EBE3D2;
  --bg-3:      #E0D6C0;
  --line:      #D4C7A8;
  --line-2:    #C2B391;
  --ink:       #1A1712;
  --ink-2:     #5D5547;
  --ink-3:     #8A8374;
  --accent:    #8C3A2A;
  --accent-2:  #3A5E4C;
  --green:     #3A5E4C;
  --yellow:    #B28034;
  --red:       #8C3A2A;
  --blue:      #4C6B8A;
}

body[data-density="cozy"] { --pad-card: 20px; --gap-md: 14px; }
body[data-density="compact"] { --pad-card: 12px; --gap-md: 8px; }
body { --pad-card: 16px; --gap-md: 12px; }

* { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
html, body { margin: 0; padding: 0; height: 100%; }
body {
  background: #0a0a0a;
  color: var(--ink);
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  font-feature-settings: 'ss01','cv11';
  letter-spacing: -0.005em;
}
button { background: none; border: 0; color: inherit; padding: 0; cursor: pointer; font: inherit; }
input, textarea, select { font: inherit; color: inherit; }

/* scene / page inside device */
.hb-app {
  width: 100%; height: 100%;
  background: var(--bg);
  color: var(--ink);
  overflow: hidden;
  position: relative;
  font-family: var(--font-sans);
}
.hb-scroll {
  height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  padding: 58px 20px 120px;   /* top clears status bar, bottom clears nav */
  scrollbar-width: none;
}
.hb-scroll::-webkit-scrollbar { display: none; }

/* typographic primitives */
.display { font-family: var(--font-display); font-weight: 400; letter-spacing: -0.03em; }
.eyebrow { font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-3); }
.mono { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }
.num { font-variant-numeric: tabular-nums; }

.hb-h1 { font-family: var(--font-display); font-weight: 400; font-size: 44px; line-height: 1.02; letter-spacing: -0.03em; color: var(--ink); margin: 0; }
.hb-italic { font-style: italic; }

/* cards */
.hb-card {
  background: var(--bg-2);
  border: 1px solid var(--line);
  border-radius: var(--radius-md);
  padding: var(--pad-card);
}
.hb-card-inset {
  background: var(--bg-3);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  padding: 12px;
}

/* buttons */
.hb-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  min-height: 48px; padding: 0 18px;
  border-radius: 14px;
  font-weight: 600; font-size: 15px; letter-spacing: -0.01em;
  transition: transform .1s ease, background .15s ease, border-color .15s ease;
}
.hb-btn:active { transform: scale(0.98); }
.hb-btn-primary {
  background: var(--ink);
  color: var(--bg);
}
.hb-btn-ghost {
  background: transparent;
  color: var(--ink-2);
  border: 1px solid var(--line-2);
}
.hb-btn-danger {
  background: var(--red);
  color: #fff;
}
.hb-btn[disabled] { opacity: 0.4; pointer-events: none; }

/* chips / pills */
.hb-chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 10px;
  border: 1px solid var(--line-2);
  border-radius: 999px;
  font-family: var(--font-mono);
  font-size: 11px; letter-spacing: 0.04em;
  color: var(--ink-2);
}

/* bottom nav */
.hb-nav {
  position: absolute;
  left: 14px; right: 14px; bottom: 20px;
  background: rgba(20,24,29,0.78);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid var(--line);
  border-radius: 24px;
  display: flex;
  align-items: stretch;
  padding: 6px;
  z-index: 30;
}
body[data-palette="paper"] .hb-nav { background: rgba(244,239,228,0.82); }
.hb-nav-item {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 2px;
  padding: 8px 0;
  border-radius: 18px;
  color: var(--ink-3);
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: background .15s, color .15s;
}
.hb-nav-item.active {
  background: var(--bg-3);
  color: var(--ink);
}

/* sheets */
.hb-sheet-backdrop {
  position: absolute; inset: 0;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(3px);
  z-index: 40;
  animation: fade .22s ease both;
}
.hb-sheet {
  position: absolute; left: 0; right: 0; bottom: 0;
  background: var(--bg-2);
  border-top-left-radius: 28px;
  border-top-right-radius: 28px;
  border-top: 1px solid var(--line);
  padding: 14px 18px 28px;
  max-height: 86%;
  overflow-y: auto;
  z-index: 41;
  animation: slide-up .3s cubic-bezier(.32,.72,0,1) both;
}
.hb-sheet-grip {
  width: 36px; height: 4px; border-radius: 4px;
  background: var(--line-2);
  margin: 0 auto 10px;
}
@keyframes slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
@keyframes fade { from { opacity: 0 } to { opacity: 1 } }

/* inputs */
.hb-input {
  width: 100%;
  background: var(--bg-3);
  border: 1px solid var(--line);
  color: var(--ink);
  border-radius: 12px;
  padding: 0 14px;
  height: 44px;
  font-size: 15px;
}
.hb-input:focus { outline: none; border-color: var(--accent); }
.hb-textarea {
  width: 100%;
  background: var(--bg-3);
  border: 1px solid var(--line);
  color: var(--ink);
  border-radius: 16px;
  padding: 12px 14px;
  font-size: 15px;
  resize: none;
  font-family: inherit;
}
.hb-textarea:focus { outline: none; border-color: var(--accent); }

/* segmented control */
.hb-seg {
  display: flex; background: var(--bg-3); border: 1px solid var(--line);
  border-radius: 12px; padding: 3px; gap: 3px;
}
.hb-seg > button {
  flex: 1; padding: 8px 4px; border-radius: 9px;
  font-size: 13px; font-weight: 500;
  color: var(--ink-2);
  transition: background .15s, color .15s;
}
.hb-seg > button.active {
  background: var(--bg);
  color: var(--ink);
  border: 1px solid var(--line-2);
  box-shadow: 0 1px 2px rgba(0,0,0,0.2);
}

/* meter (reusable risk bar) */
.hb-meter { position: relative; height: 3px; background: var(--line); border-radius: 2px; overflow: hidden; }
.hb-meter-fill { position: absolute; inset: 0 auto 0 0; background: var(--accent); transition: width .6s cubic-bezier(.32,.72,0,1); }

/* risk colors by state */
[data-risk="green"]  { --risk: var(--green); }
[data-risk="yellow"] { --risk: var(--yellow); }
[data-risk="red"]    { --risk: var(--red); }

/* tweaks panel */
.hb-tweaks {
  position: absolute;
  right: -340px;
  top: 10px;
  width: 320px;
  max-height: calc(100% - 20px);
  overflow-y: auto;
  background: #0f1115;
  border: 1px solid #222;
  border-radius: 16px;
  color: #e8e4dc;
  padding: 16px;
  font-family: var(--font-sans);
  font-size: 13px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.35);
  z-index: 100;
}
.hb-tweaks h3 {
  font-family: var(--font-display); font-weight: 400; font-size: 22px; margin: 0 0 2px;
}
.hb-tweaks .hint {
  color: #888; font-size: 11px; margin: 0 0 14px;
}
.hb-tweaks .group { margin-bottom: 14px; }
.hb-tweaks .label {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.15em;
  text-transform: uppercase; color: #888; margin-bottom: 6px;
}
.hb-tweaks .opts { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; }
.hb-tweaks .opts.full { grid-template-columns: 1fr; }
.hb-tweaks .opts button {
  padding: 8px 10px;
  border: 1px solid #222;
  border-radius: 10px;
  background: #15181d;
  color: #bbb;
  text-align: left;
  font-size: 12px;
}
.hb-tweaks .opts button.active {
  border-color: #E8C27A;
  background: #1c1c1c;
  color: #fff;
}

/* world (outside device) */
.world {
  min-height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(232,194,122,0.08), transparent 60%),
    radial-gradient(ellipse at 70% 80%, rgba(180,91,79,0.08), transparent 60%),
    #060608;
}

/* gauge / curve visuals share shared helpers */
.glow-amber { filter: drop-shadow(0 0 14px rgba(232,194,122,0.25)); }
.glow-red   { filter: drop-shadow(0 0 14px rgba(217,106,106,0.25)); }
.glow-green { filter: drop-shadow(0 0 14px rgba(127,182,138,0.25)); }

/* utility */
.flex { display: flex; }
.f-col { display: flex; flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-2 { gap: 8px; }
.gap-3 { gap: 12px; }
.gap-4 { gap: 16px; }
.w-full { width: 100%; }
.mt-1 { margin-top: 4px; } .mt-2 { margin-top: 8px; } .mt-3 { margin-top: 12px; } .mt-4 { margin-top: 16px; } .mt-6 { margin-top: 24px; } .mt-8 { margin-top: 32px; }
.mb-2 { margin-bottom: 8px; } .mb-3 { margin-bottom: 12px; } .mb-4 { margin-bottom: 16px; }

/* Toast */
.hb-toast {
  position: absolute; left: 20px; right: 20px; bottom: 110px;
  background: var(--bg-3);
  border: 1px solid var(--line-2);
  color: var(--ink);
  padding: 12px 14px;
  border-radius: 14px;
  font-size: 13px;
  z-index: 50;
  animation: slide-up .25s ease both;
}

