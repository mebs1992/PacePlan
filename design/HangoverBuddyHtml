<script>
// BAC math — ported from src/lib/bac.ts (Widmark + food-modulated absorption + zero-order elimination)

const BETA_LOW = 0.12;
const BETA_TYPICAL = 0.15;
const BETA_HIGH = 0.20;

const TARGET_PEAK_BAC = 0.055;
const RISK_GREEN_MAX = 0.04;
const RISK_YELLOW_MAX = 0.06;

const R_MALE = 0.68;
const R_FEMALE = 0.55;

const HOUR_MS = 60 * 60 * 1000;
const SIM_STEP_MS = 60_000;
const GRAMS_PER_STANDARD_DRINK_AU = 10;

const HANGOVER_PEAK_LOW = 0.05;
const HANGOVER_PEAK_MODERATE = 0.08;
const HANGOVER_PEAK_SEVERE = 0.11;
const HANGOVER_WAKE_STILL_DRUNK = 0.02;

const DRINK_PRESETS = [
  { type: 'mid_beer',  label: 'Mid beer',  sublabel: '375 ml · 3.5%',   standardDrinks: 1.0 },
  { type: 'full_beer', label: 'Full beer', sublabel: '375 ml · 4.8%',   standardDrinks: 1.4 },
  { type: 'wine',      label: 'Wine',      sublabel: '150 ml · 13%',    standardDrinks: 1.5 },
  { type: 'spirit',    label: 'Spirit',    sublabel: '30 ml · 40%',     standardDrinks: 1.0 },
  { type: 'cocktail',  label: 'Cocktail',  sublabel: 'avg 2 standard',  standardDrinks: 2.0 },
];

function widmarkR(profile) {
  return profile.sex === 'male' ? R_MALE : R_FEMALE;
}

function stomachStateAt(food, at) {
  let state = 'empty';
  for (const e of food) {
    if (e.at > at) continue;
    const h = (at - e.at) / HOUR_MS;
    if (e.size === 'meal') {
      if (h < 2) state = 'full';
      else if (h < 4 && state !== 'full') state = 'snack';
    } else if (e.size === 'snack') {
      if (h < 2 && state !== 'full') state = 'snack';
    }
  }
  return state;
}

function absorptionMinutesFor(state) {
  if (state === 'full') return 75;
  if (state === 'snack') return 45;
  return 20;
}

function computeBacAt(inputs, beta = BETA_TYPICAL) {
  const { profile, drinks, food, at } = inputs;
  const sorted = drinks.filter(d => d.at <= at).sort((a, b) => a.at - b.at);
  if (sorted.length === 0) return 0;
  const r = widmarkR(profile);
  const W = profile.weightKg;

  const plans = sorted.map(d => {
    const state = stomachStateAt(food, d.at);
    const absMs = absorptionMinutesFor(state) * 60_000;
    return {
      grams: d.standardDrinks * GRAMS_PER_STANDARD_DRINK_AU,
      start: d.at,
      end: d.at + absMs,
      absorptionMs: absMs,
    };
  });

  let bac = 0;
  let t = sorted[0].at;
  while (t < at) {
    const next = Math.min(t + SIM_STEP_MS, at);
    const dtHr = (next - t) / HOUR_MS;
    let g = 0;
    for (const p of plans) {
      if (p.absorptionMs === 0) continue;
      const a = Math.max(t, p.start);
      const b = Math.min(next, p.end);
      if (b > a) g += p.grams * ((b - a) / p.absorptionMs);
    }
    bac += g / (W * r);
    bac = Math.max(0, bac - beta * dtHr);
    t = next;
  }
  return bac / 10; // g/L → percent
}

function computeBacRange(inputs) {
  return {
    low: computeBacAt(inputs, BETA_HIGH),
    typical: computeBacAt(inputs, BETA_TYPICAL),
    high: computeBacAt(inputs, BETA_LOW),
  };
}

function riskFor(bac) {
  if (bac < RISK_GREEN_MAX) return 'green';
  if (bac < RISK_YELLOW_MAX) return 'yellow';
  return 'red';
}

function soberAtMs(inputs) {
  const cur = computeBacAt(inputs, BETA_TYPICAL);
  if (cur <= 0) return null;
  const hrs = (cur * 10) / BETA_TYPICAL;
  return inputs.at + hrs * HOUR_MS;
}

function peakBacInWindow(profile, drinks, food, fromMs, toMs) {
  if (drinks.length === 0) return 0;
  const step = 5 * 60_000;
  let peak = 0;
  for (let t = fromMs; t <= toMs; t += step) {
    const v = computeBacAt({ profile, drinks, food, at: t }, BETA_TYPICAL);
    if (v > peak) peak = v;
  }
  return peak;
}

function probeSpacingMs(drinks) {
  const D = 30 * 60_000, MIN = 20 * 60_000, MAX = 75 * 60_000;
  if (drinks.length < 2) return D;
  const s = [...drinks].sort((a, b) => a.at - b.at);
  const span = s[s.length - 1].at - s[0].at;
  if (span <= 0) return D;
  return Math.min(MAX, Math.max(MIN, span / (s.length - 1)));
}

function suggestedDrinksRemaining(inputs, sessionEndsAt, avg = 1.4, cap = TARGET_PEAK_BAC) {
  let count = 0;
  const drinks = [...inputs.drinks];
  const rem = Math.max(0, sessionEndsAt - inputs.at);
  if (rem === 0) return 0;
  const slotMs = probeSpacingMs(inputs.drinks);
  const slots = Math.max(1, Math.floor(rem / slotMs));
  for (let i = 0; i < slots; i++) {
    const at = inputs.at + i * slotMs;
    const trial = [...drinks, { id: `p${i}`, type: 'custom', label: 'p', standardDrinks: avg, at }];
    const peak = peakBacInWindow(inputs.profile, trial, inputs.food, inputs.at, sessionEndsAt + 90 * 60_000);
    if (peak > cap) break;
    drinks.push(trial[trial.length - 1]);
    count++;
  }
  return count;
}

function drinksUntilHangover(inputs, sessionEndsAt, wakeAtMs, avg = 1.4, cap = HANGOVER_PEAK_MODERATE) {
  let count = 0;
  const drinks = [...inputs.drinks];
  const rem = Math.max(0, sessionEndsAt - inputs.at);
  if (rem === 0) return 0;
  const slotMs = probeSpacingMs(inputs.drinks);
  const slots = Math.max(1, Math.floor(rem / slotMs));
  for (let i = 0; i < slots; i++) {
    const at = inputs.at + i * slotMs;
    const trial = [...drinks, { id: `p${i}`, type: 'custom', label: 'p', standardDrinks: avg, at }];
    const peak = peakBacInWindow(inputs.profile, trial, inputs.food, inputs.at, Math.max(sessionEndsAt + 90 * 60_000, wakeAtMs));
    const wake = computeBacAt({ profile: inputs.profile, drinks: trial, food: inputs.food, at: wakeAtMs }, BETA_TYPICAL);
    if (peak > cap) break;
    if (wake >= HANGOVER_WAKE_STILL_DRUNK) break;
    drinks.push(trial[trial.length - 1]);
    count++;
  }
  return count;
}

function hangoverRiskFor(peakBac, bacAtWake, waterBehindGlasses) {
  if (bacAtWake >= HANGOVER_WAKE_STILL_DRUNK) return 'severe';
  if (peakBac >= HANGOVER_PEAK_SEVERE) return 'severe';
  let tier = 'low';
  if (peakBac >= HANGOVER_PEAK_MODERATE) tier = 'high';
  else if (peakBac >= HANGOVER_PEAK_LOW) tier = 'moderate';
  if (waterBehindGlasses >= 3 && tier === 'low') tier = 'moderate';
  else if (waterBehindGlasses >= 3 && tier === 'moderate') tier = 'high';
  return tier;
}

function hangoverLabel(r) {
  return ({ low: 'Low', moderate: 'Moderate', high: 'High', severe: 'Severe' })[r];
}

function waterBehind(drinks, waterCount) {
  return drinks.length > 0 && waterCount < Math.max(0, drinks.length - 1);
}
function waterDeficit(drinks, waterCount) {
  return Math.max(0, drinks.length - 1 - waterCount);
}

// Build a BAC curve from a session, sampled as points over time
function bacCurve(profile, drinks, food, fromMs, toMs, points = 80) {
  const out = [];
  if (toMs <= fromMs) return out;
  const step = (toMs - fromMs) / points;
  for (let i = 0; i <= points; i++) {
    const at = fromMs + step * i;
    out.push({ at, bac: computeBacAt({ profile, drinks, food, at }, BETA_TYPICAL) });
  }
  return out;
}

window.BAC = {
  BETA_TYPICAL, TARGET_PEAK_BAC, RISK_GREEN_MAX, RISK_YELLOW_MAX,
  GRAMS_PER_STANDARD_DRINK_AU, DRINK_PRESETS,
  computeBacAt, computeBacRange, riskFor, soberAtMs, peakBacInWindow,
  suggestedDrinksRemaining, drinksUntilHangover,
  hangoverRiskFor, hangoverLabel, waterBehind, waterDeficit, bacCurve,
};

</script>
<script>
// Zustand-free store using React hooks + localStorage.

const STORAGE_KEY = 'hangover-buddy-redesign:v1';

function nanoid() {
  return Math.random().toString(36).slice(2, 10) + Date.now().toString(36).slice(-4);
}

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return defaultState();
    const p = JSON.parse(raw);
    return { ...defaultState(), ...p };
  } catch { return defaultState(); }
}

function defaultState() {
  return {
    profile: null,
    active: null,
    history: [],
    // visual tweaks
    palette: 'dusk',       // dusk | neon | paper
    density: 'comfortable',
    visual: 'curve',       // curve | orb | ring | numeric
    simState: 'real',      // real | dry | midnight | overlimit
    showIntro: true,
  };
}

function saveState(s) {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
  } catch {}
}

// a tiny pub/sub store
const listeners = new Set();
let state = loadState();

function getState() { return state; }
function setState(patch) {
  state = typeof patch === 'function' ? patch(state) : { ...state, ...patch };
  saveState(state);
  for (const l of listeners) l(state);
}
function subscribe(fn) { listeners.add(fn); return () => listeners.delete(fn); }

function useStore(selector = s => s) {
  const [val, setVal] = React.useState(() => selector(state));
  React.useEffect(() => {
    return subscribe(s => {
      const next = selector(s);
      setVal(prev => (Object.is(prev, next) ? prev : next));
    });
  }, []);
  return val;
}

// actions
const actions = {
  setProfile(profile) { setState({ profile }); },
  resetAll() {
    localStorage.removeItem(STORAGE_KEY);
    state = defaultState();
    for (const l of listeners) l(state);
  },
  startSession({ expectedHours, wakeAtMs, planToDrive }) {
    setState({
      active: {
        id: nanoid(),
        startedAt: Date.now(),
        expectedHours,
        drinks: [], food: [], water: [],
        wakeAtMs, planToDrive: !!planToDrive,
      },
    });
  },
  endSession({ peakBac, predictedRisk }) {
    const { active, history } = state;
    if (!active) return null;
    const ended = { ...active, endedAt: Date.now(), peakBac, predictedRisk };
    setState({ active: null, history: [ended, ...history].slice(0, 30) });
    return ended.id;
  },
  setExpectedHours(h) {
    if (!state.active) return;
    setState({ active: { ...state.active, expectedHours: h } });
  },
  setWakeAt(ms) {
    if (!state.active) return;
    setState({ active: { ...state.active, wakeAtMs: ms } });
  },
  setPlanToDrive(v) {
    if (!state.active) return;
    setState({ active: { ...state.active, planToDrive: v } });
  },
  addDrink({ type, label, standardDrinks }) {
    if (!state.active) return;
    const entry = { id: nanoid(), type, label, standardDrinks, at: Date.now() };
    setState({ active: { ...state.active, drinks: [...state.active.drinks, entry] } });
  },
  removeDrink(id) {
    if (!state.active) return;
    setState({ active: { ...state.active, drinks: state.active.drinks.filter(d => d.id !== id) } });
  },
  addFood(size) {
    if (!state.active) return;
    const entry = { id: nanoid(), size, at: Date.now() };
    setState({ active: { ...state.active, food: [...state.active.food, entry] } });
  },
  removeFood(id) {
    if (!state.active) return;
    setState({ active: { ...state.active, food: state.active.food.filter(f => f.id !== id) } });
  },
  addWater() {
    if (!state.active) return;
    const entry = { id: nanoid(), at: Date.now() };
    setState({ active: { ...state.active, water: [...state.active.water, entry] } });
  },
  removeWater(id) {
    if (!state.active) return;
    setState({ active: { ...state.active, water: state.active.water.filter(w => w.id !== id) } });
  },
  submitRecap(id, recap) {
    setState({ history: state.history.map(s => s.id === id ? { ...s, recap } : s) });
  },
  setVisual(v) { setState({ visual: v }); },
  setPalette(p) { setState({ palette: p }); },
  setDensity(d) { setState({ density: d }); },
  setSimState(k) { setState({ simState: k }); },
  setShowIntro(v) { setState({ showIntro: v }); },
  // demo seeding
  seedSimState(kind) {
    // Build a fake session based on tweak choice
    const now = Date.now();
    const profile = state.profile || {
      name: 'Sam', sex: 'male', heightCm: 180, weightKg: 78, age: 30, acceptedDisclaimerAt: now,
    };
    if (kind === 'dry') {
      setState({
        profile,
        active: {
          id: nanoid(),
          startedAt: now - 20 * 60_000,
          expectedHours: 5,
          drinks: [],
          food: [{ id: nanoid(), size: 'meal', at: now - 40 * 60_000 }],
          water: [],
          wakeAtMs: new Date().setHours(8, 0, 0, 0) + 24 * 3600_000,
          planToDrive: false,
        },
      });
    } else if (kind === 'midnight') {
      const start = now - 2.5 * 3600_000;
      setState({
        profile,
        active: {
          id: nanoid(),
          startedAt: start,
          expectedHours: 5,
          drinks: [
            { id: nanoid(), type: 'full_beer', label: 'Full beer', standardDrinks: 1.4, at: start + 15 * 60_000 },
            { id: nanoid(), type: 'full_beer', label: 'Full beer', standardDrinks: 1.4, at: start + 55 * 60_000 },
            { id: nanoid(), type: 'wine',      label: 'Wine',      standardDrinks: 1.5, at: start + 95 * 60_000 },
            { id: nanoid(), type: 'spirit',    label: 'Spirit',    standardDrinks: 1.0, at: start + 130 * 60_000 },
          ],
          food: [{ id: nanoid(), size: 'meal', at: start - 30 * 60_000 }],
          water: [{ id: nanoid(), at: start + 40 * 60_000 }],
          wakeAtMs: (() => { const d = new Date(); d.setDate(d.getDate() + 1); d.setHours(8, 0, 0, 0); return d.getTime(); })(),
          planToDrive: false,
        },
      });
    } else if (kind === 'overlimit') {
      const start = now - 3 * 3600_000;
      setState({
        profile,
        active: {
          id: nanoid(),
          startedAt: start,
          expectedHours: 5,
          drinks: [
            { id: nanoid(), type: 'spirit',    label: 'Spirit',    standardDrinks: 1.2, at: start + 10 * 60_000 },
            { id: nanoid(), type: 'cocktail',  label: 'Cocktail',  standardDrinks: 2.0, at: start + 40 * 60_000 },
            { id: nanoid(), type: 'cocktail',  label: 'Cocktail',  standardDrinks: 2.0, at: start + 75 * 60_000 },
            { id: nanoid(), type: 'full_beer', label: 'Full beer', standardDrinks: 1.4, at: start + 110 * 60_000 },
            { id: nanoid(), type: 'spirit',    label: 'Spirit',    standardDrinks: 1.2, at: start + 145 * 60_000 },
            { id: nanoid(), type: 'full_beer', label: 'Full beer', standardDrinks: 1.4, at: start + 170 * 60_000 },
          ],
          food: [],
          water: [],
          wakeAtMs: (() => { const d = new Date(); d.setDate(d.getDate() + 1); d.setHours(8, 0, 0, 0); return d.getTime(); })(),
          planToDrive: false,
        },
      });
    }
    // 'real' leaves active alone
  },
};

window.HB = { useStore, getState, setState, actions, nanoid };

</script>

